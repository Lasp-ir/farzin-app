generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" 
}

// ==========================================
// 🛡️ سیستم کاربران و احراز هویت
// ==========================================
model User {
  id               Int      @id @default(autoincrement())
  username         String   @unique
  email            String   @unique
  password         String
  role             String   @default("user") // "user" یا "admin"
  
  // اطلاعات پازل
  puzzleRating     Int      @default(1200)
  puzzleStreak     Int      @default(0)
  maxStreak        Int      @default(0)
  quotaMistakes    Int      @default(3)
  quotaRated       Int      @default(5)
  quotaThemes      Int      @default(5)
  quotaRush        Int      @default(1)
  lastQuotaReset   DateTime @default(now())
  failedPuzzles    String   @default("[]")
  connectedLichess String   @default("[]") 
  connectedChesscom String  @default("[]")
  
  // اطلاعات مالی و دوره‌ها
  gems             Int      @default(0)
  courses          UserCourse[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// 🧩 جدول پازل‌های عمومی (ربات و تمرینات روزانه)
model Puzzle {
  puzzleId         String   @id @unique
  fen              String
  moves            String   
  rating           Int
  themes           String   
  
  @@index([rating])
  @@index([themes])
}



// 🎯 جدول پیشرفت کاربر در دوره‌ها
model UserCourse {
  id        String   @id @default(uuid())
  
  userId    Int      
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  progress  Int      @default(0) // درصد پیشرفت (۰ تا ۱۰۰)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}