generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" 
}

// ==========================================
// 🛡️ سیستم کاربران و احراز هویت
// ==========================================
model User {
  id               Int      @id @default(autoincrement())
  username         String   @unique
  email            String   @unique
  password         String
  role             String   @default("user") // "user" یا "admin"
  
  // اطلاعات پازل
  puzzleRating     Int      @default(1200)
  puzzleStreak     Int      @default(0)
  maxStreak        Int      @default(0)
  quotaMistakes    Int      @default(3)
  quotaRated       Int      @default(5)
  quotaThemes      Int      @default(5)
  quotaRush        Int      @default(1)
  lastQuotaReset   DateTime @default(now())
  failedPuzzles    String   @default("[]")
  connectedLichess String   @default("[]") 
  connectedChesscom String  @default("[]")
  
  // اطلاعات مالی و دوره‌ها
  gems             Int      @default(0)
  courses          UserCourse[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// 🧩 جدول پازل‌های عمومی (ربات و تمرینات روزانه)
model Puzzle {
  puzzleId         String   @id @unique
  fen              String
  moves            String   
  rating           Int
  themes           String   
  
  @@index([rating])
  @@index([themes])
}

// ==========================================
// 🎓 سیستم اساتید (جدید)
// ==========================================
model Instructor {
  id        String   @id @default(uuid())
  name      String   @unique    // 👈 کلمه @unique باید حتماً اینجا اضافه شود
  title     String
  bio       String
  avatar    String
  
  courses   Course[]            // 👈 (احتمالاً این خط رو هم پریزما ازت بخواد برای ارتباط دوطرفه)
}

// ==========================================
// 📚 سیستم آموزشی و ویدیوها
// ==========================================
model Course {
  id             String       @id @default(uuid())
  title          String
  category       String
  level          String
  duration       String
  image          String
  description    String
  requirements   String
  isPremium      Boolean      @default(true)
  price          Int          @default(0)
  discount       Int          @default(0)    // 👈 این خط حتماً باید اینجا باشه

  instructor     String
  instructorProfile Instructor? @relation(fields: [instructor], references: [name])
  
  lessons        Lesson[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  enrollments    UserCourse[]
}

// 🎥 جدول جلسات هر دوره
model Lesson {
  id            String   @id @default(uuid())
  title         String
  videoUrl      String
  duration      String
  order         Int
  isFreePreview Boolean  @default(false)
  
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  exercises     LessonExercise[] // 🔥 ارتباط جلسه با تمرینات تعاملی
  
  createdAt     DateTime @default(now())
}

// ==========================================
// ♟️ ماشین حل تمرینات تعاملی (جدید)
// ==========================================
model LessonExercise {
  id          String   @id @default(uuid())
  fen         String   // پوزیشن اولیه چیده شده روی تخته
  moves       String   // جواب پازل (مثلا e2e4 e7e5)
  description String   @default("") // متنی که استاد برای توضیح این حرکت نوشته
  hints       String   @default("[]") // راهنمایی‌ها به صورت آرایه‌ای از متون (JSON String)
  order       Int      @default(1) // ترتیب نمایش تمرین‌ها در یک جلسه
  
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

// ==========================================
// 🧩 پازل‌های شخصی (Maia Individual)
// ==========================================
model PersonalPuzzleRequest {
  id          String   @id @default(uuid())
  userId      Int?
  lichessIds  String   @default("[]")
  chesscomIds String   @default("[]")
  gameCount   Int      @default(5)
  status      String   @default("pending") // pending | processing | done | error
  contactInfo String   @default("")
  puzzles     String   @default("[]")
  adminNote   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 🔔 سیستم اعلان‌ها
// ==========================================
model Notification {
  id         String   @id @default(uuid())
  userId     Int?
  type       String
  title      String
  body       String
  isRead     Boolean  @default(false)
  actionUrl  String   @default("")
  data       String   @default("{}")
  createdAt  DateTime @default(now())
}

// 🎯 جدول پیشرفت کاربر در دوره‌ها
model UserCourse {
  id        String   @id @default(uuid())
  
  userId    Int      
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  progress  Int      @default(0) // درصد پیشرفت (۰ تا ۱۰۰)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}